    {
      "parameters": {
        "jsCode": "const data = $input.first().json.data;\nconst html = data;\n// Improved regex: handles quotes better, multiline text with [\\s\\S]*?, more attributes\nconst matches = [...html.matchAll(/<a\\s+href=([\"'])((?:(?!\\1).)*)\\1[^>]*>([\\s\\S]*?)<\\/a>/gi)];\nconst trending = matches\n  .map(m => ({ trend: m[3].trim() }))  // Use group 3 for text, trim whitespace\n  .filter(item => !item.trend.includes('#'))\n  .slice(0,$('Edit Fields').first().json['total posts'] );\nreturn trending;\n"
      },
